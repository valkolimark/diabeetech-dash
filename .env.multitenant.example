# Nightscout Multi-Tenant Configuration Example
# Copy this file to .env and update with your values

# Enable multi-tenant mode
MULTI_TENANT_ENABLED=true

# Master database for tenant and user management
# This should point to a separate database from your data
MASTER_MONGODB_URI=mongodb://user:password@localhost:27017/nightscout_master

# Original MongoDB URI (used as fallback and for base connection)
MONGODB_URI=mongodb://user:password@localhost:27017/nightscout

# Prefix for tenant databases
TENANT_DB_PREFIX=nightscout_tenant_

# JWT Configuration
JWT_SECRET=your-very-secret-jwt-key-change-this-in-production
JWT_EXPIRES_IN=24h
JWT_REFRESH_EXPIRES_IN=7d

# Base domain for tenant subdomains
# e.g., if BASE_DOMAIN=nightscout.com, tenants will be at tenant1.nightscout.com
BASE_DOMAIN=localhost

# Default tenant (optional, for single-tenant compatibility mode)
DEFAULT_TENANT=demo

# Enable subdomain-based tenant resolution
TENANT_SUBDOMAIN_ENABLED=true

# Allow API_SECRET fallback for backward compatibility
ENABLE_API_SECRET_FALLBACK=true

# Authentication settings
AUTH_ENABLE_COOKIES=false

# Standard Nightscout settings
NODE_ENV=production
PORT=1337
HOSTNAME=0.0.0.0

# Security settings
INSECURE_USE_HTTP=false
SECURE_HSTS_HEADER=true
SECURE_CSP=false

# API settings (optional, for system admin access)
API_SECRET=your-api-secret-min-12-chars

# Features to enable
ENABLE=careportal rawbg iob cob bwp cage iage sage boluscalc pushover treatmentnotify

# Display settings
DISPLAY_UNITS=mg/dl
NIGHT_MODE=off

# Alarm settings
ALARM_URGENT_HIGH=260
ALARM_HIGH=200
ALARM_LOW=70
ALARM_URGENT_LOW=55

# MongoDB connection pool settings (for better multi-tenant performance)
MONGO_POOL_SIZE=10
MONGO_MAX_POOL_SIZE=50

# Session settings
SESSION_SECRET=your-session-secret-change-this

# Email settings (for password reset, notifications)
EMAIL_ENABLE=true
EMAIL_FROM=noreply@nightscout.com
EMAIL_SMTP_HOST=smtp.gmail.com
EMAIL_SMTP_PORT=587
EMAIL_SMTP_SECURE=false
EMAIL_SMTP_USER=your-email@gmail.com
EMAIL_SMTP_PASS=your-app-password

# Heroku specific settings
# If deploying to Heroku, these will be set automatically
# HEROKU_API_KEY=your-heroku-api-key
# HEROKU_APP_NAME=your-app-name