    {
      "name": "Multi-Tenant",
      "item": [
        {
          "name": "Register Tenant",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 201) {",
                  "    const response = pm.response.json();",
                  "    pm.test('Tenant registered successfully', () => {",
                  "        pm.expect(response).to.have.property('message');",
                  "        pm.expect(response.tenant).to.have.property('subdomain');",
                  "        pm.expect(response).to.have.property('loginUrl');",
                  "    });",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "auth": {
              "type": "noauth"
            },
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"subdomain\": \"my-clinic\",\n  \"adminEmail\": \"admin@clinic.com\",\n  \"adminPassword\": \"AdminPassword123!\",\n  \"adminName\": \"Clinic Admin\",\n  \"hCaptchaResponse\": \"captcha-token-here\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/tenants/register",
              "host": ["{{baseUrl}}"],
              "path": ["tenants", "register"]
            }
