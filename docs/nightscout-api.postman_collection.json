  "event": [
    {
      "listen": "prerequest",
      "script": {
        "type": "text/javascript",
        "exec": [
          "// Add timestamp for requests",
          "pm.variables.set('timestamp', new Date().toISOString());",
          "",
          "// Helper to generate SHA-1 hash for API secret",
          "if (pm.variables.get('apiSecretRaw')) {",
          "    const CryptoJS = require('crypto-js');",
          "    const hashedSecret = CryptoJS.SHA1(pm.variables.get('apiSecretRaw')).toString();",
          "    pm.collectionVariables.set('apiSecret', hashedSecret);",
          "}"
        ]
      }
    },
    {
      "listen": "test",
      "script": {
        "type": "text/javascript",
        "exec": [
          "// Global tests",
          "pm.test('Response time is less than 1000ms', () => {",
          "    pm.expect(pm.response.responseTime).to.be.below(1000);",
          "});",
          "",
          "// Check for common errors",
          "if (pm.response.code === 401) {",
          "    console.log('Authentication failed - check your access token');",
          "}",
          "",
          "if (pm.response.code === 429) {",
          "    console.log('Rate limit exceeded - wait before retrying');",
          "}"
        ]
      }
    }
  ]
